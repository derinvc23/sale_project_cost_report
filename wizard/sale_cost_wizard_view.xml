<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="sale_cost_wizard_view_form" model="ir.ui.view">
            <field name="name">sale.cost.wizard.form</field>
            <field name="model">sale.cost.wizard</field>
            <field name="arch" type="xml">
                <form string="Reporte Costos y Márgenes por Proyecto">
                    <group>
                        <group string="Período">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Filtros opcionales">
                            <field name="partner_id"/>
                            <field name="warehouse_id"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_view_report"
                                type="object"
                                string="Ver Reporte"
                                class="oe_highlight"/>
                        <button string="Cancelar" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_sale_cost_wizard" model="ir.actions.act_window">
            <field name="name">Costos y Márgenes por Proyecto</field>
            <field name="res_model">sale.cost.wizard</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
